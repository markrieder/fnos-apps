#!/bin/bash

service_postinst() {
    local env_file="${TRIM_APPDEST}/docker/.env"
    local need_env=false

    mkdir -p "${TRIM_PKGVAR}/config" 2>/dev/null || true

    : > "$env_file"
    if [ -n "${wizard_wg_host}" ]; then
        echo "WG_HOST=${wizard_wg_host}" >> "$env_file"
        need_env=true
    fi
    if [ -n "${wizard_password}" ]; then
        echo "PASSWORD_HASH=${wizard_password}" >> "$env_file"
        need_env=true
    fi

    if [ "$need_env" = true ]; then
        chmod 600 "$env_file"
        install_log "Wrote docker .env with wizard values"
    else
        rm -f "$env_file"
    fi
}
