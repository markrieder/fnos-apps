#!/bin/sh
APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR=$1

mkdir -p "$APP_DATA_DIR/data" "$APP_DATA_DIR/logs"

if [ ! -f "$APP_DATA_DIR/grafana.ini" ] && [ -f "$APP_DIR/conf/sample.ini" ]; then
    cp "$APP_DIR/conf/sample.ini" "$APP_DATA_DIR/grafana.ini"
fi

cd "$APP_DIR" || exit 1
exec ./bin/grafana server --homepath "$APP_DIR" --config "$APP_DATA_DIR/grafana.ini" --pidfile "$APP_DATA_DIR/grafana.pid" cfg:server.http_port=${TRIM_SERVICE_PORT:-3010} cfg:paths.data="$APP_DATA_DIR/data" cfg:paths.logs="$APP_DATA_DIR/logs"
