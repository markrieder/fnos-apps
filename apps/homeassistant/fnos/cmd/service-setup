#!/bin/bash

service_postinst() {
    mkdir -p "${TRIM_PKGVAR}/config" 2>/dev/null || true
    
    install_hacs
}

install_hacs() {
    local hacs_src="${TRIM_APPDEST}/extras/hacs"
    local hacs_dest="${TRIM_PKGVAR}/config/custom_components/hacs"
    
    if [ ! -d "$hacs_src" ]; then
        install_log "HACS source not found in app package, skipping HACS installation"
        return 0
    fi
    
    if [ -d "$hacs_dest" ]; then
        install_log "HACS already installed at ${hacs_dest}, skipping"
        return 0
    fi
    
    mkdir -p "${TRIM_PKGVAR}/config/custom_components" 2>/dev/null || true
    
    if cp -r "$hacs_src" "$hacs_dest" 2>/dev/null; then
        install_log "HACS installed successfully to ${hacs_dest}"
    else
        install_log "Failed to install HACS, continuing without HACS"
    fi
}

COMPOSE_FILE="${TRIM_APPDEST}/docker/docker-compose.yaml"
PORT_SAVE="${TRIM_PKGVAR}/.port"

apply_port() {
    local port="$1"
    [ -z "$port" ] && return
    echo "${port}" > "$PORT_SAVE"
    install_log "Saved custom port: ${port}"
}

service_postupgrade() {
    if [ -f "$PORT_SAVE" ]; then
        apply_port "$(cat "$PORT_SAVE")"
    fi
    
    install_hacs
}

service_postconfig() {
    if [ -n "${wizard_port:-}" ]; then
        apply_port "${wizard_port}"
    fi
}
