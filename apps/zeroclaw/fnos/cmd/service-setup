#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.log"
PID_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.pid"

APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR="${TRIM_PKGVAR}"

SERVICE_COMMAND="$APP_DIR/bin/zeroclaw-server $APP_DATA_DIR"
SVC_BACKGROUND=y
SVC_WRITE_PID=y

service_postinst() {
    # 创建配置和数据目录
    mkdir -p "${TRIM_PKGVAR}/data" 2>/dev/null || true
    mkdir -p "${TRIM_PKGVAR}/.zeroclaw" 2>/dev/null || true
}

service_postupgrade() {
    service_postinst
}

service_preuninst() {
    # 兜底：确保 zeroclaw 进程被完全终止
    pkill -x "zeroclaw" 2>/dev/null || true
    sleep 1
    pkill -9 -x "zeroclaw" 2>/dev/null || true
}

service_poststop() {
    service_preuninst
}
