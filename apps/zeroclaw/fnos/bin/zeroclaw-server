#!/bin/sh
APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR=$1

DATA_DIR="$APP_DATA_DIR/data"
CONFIG_DIR="$APP_DATA_DIR/.zeroclaw"
mkdir -p "$DATA_DIR" "$CONFIG_DIR"

export HOME="$APP_DATA_DIR"
export ZEROCLAW_GATEWAY_PORT="${TRIM_SERVICE_PORT}"
export ZEROCLAW_ALLOW_PUBLIC_BIND="true"
export ZEROCLAW_WORKSPACE="$DATA_DIR"

cd "$APP_DIR" || exit 1
exec ./zeroclaw gateway
