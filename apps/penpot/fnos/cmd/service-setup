#!/bin/bash

service_postinst() {
    mkdir -p "${TRIM_PKGVAR}/db" "${TRIM_PKGVAR}/assets" "${TRIM_PKGVAR}/redis" 2>/dev/null || true

    local env_file="${TRIM_APPDEST}/docker/.env"
    if [ ! -f "$env_file" ]; then
        local secret_key
        secret_key=$(openssl rand -hex 32)

        cat > "$env_file" << EOF
PENPOT_SECRET_KEY=${secret_key}
PENPOT_PUBLIC_URI=http://127.0.0.1:${TRIM_SERVICE_PORT}
EOF
        chmod 600 "$env_file"
        install_log "Initialized Penpot docker .env"
    fi
}

service_preupgrade() {
    if [ -f "${TRIM_APPDEST}/docker/.env" ]; then
        cp "${TRIM_APPDEST}/docker/.env" "${TRIM_PKGVAR}/.env.bak"
    fi
}

service_restore() {
    if [ -f "${TRIM_PKGVAR}/.env.bak" ]; then
        cp "${TRIM_PKGVAR}/.env.bak" "${TRIM_APPDEST}/docker/.env"
        rm -f "${TRIM_PKGVAR}/.env.bak"
    fi
}
