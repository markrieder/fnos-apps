#!/bin/bash

# ============================================================================
# OpenClaw 守护进程管理脚本 (main)
# 飞牛 OS 通过调用此脚本的 start/stop/restart/status 管理应用生命周期
# ============================================================================

APP_NAME="openclaw"
LOG_FILE="${TRIM_PKGVAR}/${APP_NAME}.log"
PID_FILE="${TRIM_PKGVAR}/${APP_NAME}.pid"

# 内嵌运行时路径
NODE_DIR="${TRIM_APPDEST}/server/node"
NODE_BIN="${NODE_DIR}/bin/node"
OC_GLOBAL="${TRIM_APPDEST}/server/openclaw_global"
OC_BIN="${OC_GLOBAL}/bin/openclaw"
OC_DATA_DIR="${TRIM_PKGVAR}/data"
OC_CONFIG_FILE="${OC_DATA_DIR}/.openclaw/openclaw.json"

GATEWAY_PORT="18789"
PROXY_PORT="18790"
PROXY_PID_FILE="${TRIM_PKGVAR}/${APP_NAME}_proxy.pid"
IFRAME_PROXY="${TRIM_APPDEST}/server/iframe-proxy.js"

# 确保日志目录存在
mkdir -p "$(dirname "${LOG_FILE}")"

# 日志函数
log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "${LOG_FILE}"
}

# 检查进程是否在运行
check_process() {
    local pid=$1
    if [ -z "${pid}" ]; then
        return 1
    fi
    if ps -p "${pid}" > /dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

# 检查应用状态
status() {
    if [ -f "${PID_FILE}" ]; then
        local pid
        pid=$(cat "${PID_FILE}" 2>/dev/null)
        if check_process "${pid}"; then
            log_msg "${APP_NAME} 正在运行 (PID: ${pid})"
            return 0
        else
            log_msg "${APP_NAME} 进程已停止，但 PID 文件存在 (PID: ${pid})"
            rm -f "${PID_FILE}"
            return 1
        fi
    else
        log_msg "${APP_NAME} 未运行"
        return 3
    fi
}

# 启动应用
start_process() {
    if status > /dev/null 2>&1; then
        log_msg "${APP_NAME} 已经在运行"
        return 0
    fi

    log_msg "正在启动 ${APP_NAME}..."

    # 检查 Node.js
    if [ ! -x "${NODE_BIN}" ]; then
        log_msg "❌ 错误: Node.js 未找到: ${NODE_BIN}"
        return 1
    fi

    # 检查 OpenClaw
    if [ ! -f "${OC_BIN}" ]; then
        log_msg "❌ 错误: OpenClaw 未找到: ${OC_BIN}"
        return 1
    fi

    # 确保数据目录权限正确
    if [ -d "${OC_DATA_DIR}" ]; then
        chown -R openclaw:openclaw "${OC_DATA_DIR}" 2>/dev/null || true
    fi

    log_msg "Node.js 版本: $(${NODE_BIN} --version)"
    log_msg "OpenClaw 路径: ${OC_BIN}"
    log_msg "数据目录: ${OC_DATA_DIR}"
    log_msg "配置文件: ${OC_CONFIG_FILE}"

    # 启动 OpenClaw Gateway
    (
        export PATH="${NODE_DIR}/bin:${OC_GLOBAL}/bin:${PATH}"
        export NODE_PATH="${OC_GLOBAL}/lib/node_modules"
        export HOME="${OC_DATA_DIR}"
        export OPENCLAW_HOME="${OC_DATA_DIR}"
        export OPENCLAW_CONFIG_PATH="${OC_CONFIG_FILE}"
        export OPENCLAW_STATE_DIR="${OC_DATA_DIR}/.openclaw"

        cd "${OC_DATA_DIR}" || exit 1

        # 读取 token
        local GW_TOKEN=""
        if [ -f "${TRIM_PKGVAR}/gateway_token" ]; then
            GW_TOKEN=$(cat "${TRIM_PKGVAR}/gateway_token" 2>/dev/null)
        fi

        # 构建启动参数
        local GW_ARGS="--port ${GATEWAY_PORT}"
        if [ -n "${GW_TOKEN}" ]; then
            GW_ARGS="${GW_ARGS} --token ${GW_TOKEN}"
        fi

        # 以 openclaw 用户启动网关（前台模式，由后台子 shell 接管）
        if id openclaw &>/dev/null; then
            sudo -u openclaw \
                env "HOME=${OC_DATA_DIR}" \
                    "PATH=${NODE_DIR}/bin:${OC_GLOBAL}/bin:/usr/local/bin:/usr/bin:/bin" \
                    "NODE_PATH=${OC_GLOBAL}/lib/node_modules" \
                    "OPENCLAW_HOME=${OC_DATA_DIR}" \
                    "OPENCLAW_CONFIG_PATH=${OC_CONFIG_FILE}" \
                    "OPENCLAW_STATE_DIR=${OC_DATA_DIR}/.openclaw" \
                bash -c "cd '${OC_DATA_DIR}' && openclaw gateway ${GW_ARGS}"
        else
            openclaw gateway ${GW_ARGS}
        fi
    ) >> "${LOG_FILE}" 2>&1 &

    # 保存进程 ID
    echo $! > "${PID_FILE}"
    log_msg "${APP_NAME} 已启动 (PID: $(cat "${PID_FILE}"))"

    # 等待端口就绪
    local ready=0
    for i in $(seq 1 15); do
        sleep 2
        if ss -ltn 2>/dev/null | grep -q ":${GATEWAY_PORT}"; then
            ready=1
            break
        fi
    done

    if [ $ready -eq 1 ]; then
        log_msg "✅ Gateway 已在端口 ${GATEWAY_PORT} 上就绪"

        # 启动 iframe 反向代理
        log_msg "正在启动 iframe 代理 (端口 ${PROXY_PORT})..."
        local GW_TOKEN=""
        if [ -f "${TRIM_PKGVAR}/gateway_token" ]; then
            GW_TOKEN=$(cat "${TRIM_PKGVAR}/gateway_token" 2>/dev/null)
        fi

        GATEWAY_PORT="${GATEWAY_PORT}" \
        PROXY_PORT="${PROXY_PORT}" \
        GATEWAY_TOKEN="${GW_TOKEN}" \
        TOKEN_FILE="${TRIM_PKGVAR}/gateway_token" \
        "${NODE_BIN}" "${IFRAME_PROXY}" >> "${LOG_FILE}" 2>&1 &
        echo $! > "${PROXY_PID_FILE}"
        log_msg "✅ iframe 代理已启动 (PID: $(cat "${PROXY_PID_FILE}"), 端口: ${PROXY_PORT})"
    else
        log_msg "⚠️  等待端口就绪超时，Gateway 可能仍在初始化中"
    fi

    return 0
}

# 停止应用
stop_process() {
    log_msg "正在停止 ${APP_NAME}..."

    if [ -f "${PID_FILE}" ]; then
        local pid
        pid=$(cat "${PID_FILE}" 2>/dev/null)

        if [ -n "${pid}" ] && check_process "${pid}"; then
            log_msg "正在停止进程 (PID: ${pid})..."
            kill -TERM "${pid}" 2>/dev/null

            local count=0
            while check_process "${pid}" && [ $count -lt 10 ]; do
                sleep 1
                count=$((count + 1))
                log_msg "等待进程结束... (${count}s/10s)"
            done

            if check_process "${pid}"; then
                log_msg "强制终止进程 (PID: ${pid})..."
                kill -9 "${pid}" 2>/dev/null
            fi
        fi

        rm -f "${PID_FILE}"
    fi

    # 停止 iframe 代理
    if [ -f "${PROXY_PID_FILE}" ]; then
        local proxy_pid
        proxy_pid=$(cat "${PROXY_PID_FILE}" 2>/dev/null)
        if [ -n "${proxy_pid}" ] && check_process "${proxy_pid}"; then
            log_msg "停止 iframe 代理 (PID: ${proxy_pid})..."
            kill -TERM "${proxy_pid}" 2>/dev/null
            sleep 1
            check_process "${proxy_pid}" && kill -9 "${proxy_pid}" 2>/dev/null
        fi
        rm -f "${PROXY_PID_FILE}"
    fi

    # 兜底清理
    pkill -f "openclaw.*gateway" 2>/dev/null || true
    pkill -f "iframe-proxy" 2>/dev/null || true

    log_msg "${APP_NAME} 已停止"
}

# 重启应用
restart_process() {
    stop_process
    sleep 2
    start_process
}

# 主逻辑
case "$1" in
    start)
        start_process
        ;;
    stop)
        stop_process
        ;;
    restart)
        restart_process
        ;;
    status)
        if status; then
            exit 0
        else
            exit 3
        fi
        ;;
    *)
        echo "使用方法: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0
