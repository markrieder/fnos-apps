#!/bin/bash

################################################################################
# OpenClaw 公共函数库
# 包含安装、卸载、升级过程中使用的公共函数
################################################################################

# ============================================================================
# 工具快捷方式
# ============================================================================
MV="/bin/mv -f"
RM="/bin/rm -rf"
CP="/bin/cp -rfp"
MKDIR="/bin/mkdir -p"
LN="/bin/ln -nsf"

# ============================================================================
# 应用信息
# ============================================================================
APP_NAME="openclaw"
APP_USER="openclaw"
APP_GROUP="openclaw"
GATEWAY_PORT="18789"

# ============================================================================
# 路径定义
# ============================================================================
INST_ETC="/var/apps/${TRIM_APPNAME}/etc"
INST_LOG="/var/log/apps/${TRIM_APPNAME}.log"

LOG_FILE="${TRIM_PKGVAR}/${APP_NAME}.log"
PID_FILE="${TRIM_PKGVAR}/${APP_NAME}.pid"

# 内嵌运行时路径
NODE_DIR="${TRIM_APPDEST}/server/node"
NODE_BIN="${NODE_DIR}/bin/node"
OC_GLOBAL="${TRIM_APPDEST}/server/openclaw_global"
OC_BIN="${OC_GLOBAL}/bin/openclaw"

# OpenClaw 数据/配置目录
OC_DATA_DIR="${TRIM_PKGVAR}/data"
OC_CONFIG_DIR="${OC_DATA_DIR}/.openclaw"
OC_CONFIG_FILE="${OC_CONFIG_DIR}/openclaw.json"

# ============================================================================
# 日志函数
# ============================================================================
install_log()
{
    local _msg_="$@"
    if [ -z "${_msg_}" ]; then
        while IFS=$'\n' read -r line; do
            install_log "${line}"
        done
    else
        echo -e "$(date +'%Y/%m/%d %H:%M:%S')\t${_msg_}" 1>&2
    fi
}

log_step()
{
    install_log "===> Step $1. STATUS=${TRIM_APP_STATUS} PKGVAR=${TRIM_PKGVAR}"
}

# ============================================================================
# 环境设置：构建 OpenClaw 运行所需的 PATH 和环境变量
# ============================================================================
setup_openclaw_env()
{
    export PATH="${NODE_DIR}/bin:${OC_GLOBAL}/bin:${PATH}"
    export NODE_PATH="${OC_GLOBAL}/lib/node_modules"
    export OPENCLAW_HOME="${OC_DATA_DIR}"
    export OPENCLAW_CONFIG_PATH="${OC_CONFIG_FILE}"
    export OPENCLAW_STATE_DIR="${OC_DATA_DIR}/.openclaw"
    export HOME="${OC_DATA_DIR}"
}

# 以 openclaw 用户身份执行命令
run_as_openclaw()
{
    local cmd="$1"
    setup_openclaw_env

    if id "${APP_USER}" &>/dev/null; then
        sudo -u "${APP_USER}" \
            env "HOME=${OC_DATA_DIR}" \
                "PATH=${NODE_DIR}/bin:${OC_GLOBAL}/bin:/usr/local/bin:/usr/bin:/bin" \
                "NODE_PATH=${OC_GLOBAL}/lib/node_modules" \
                "OPENCLAW_HOME=${OC_DATA_DIR}" \
                "OPENCLAW_CONFIG_PATH=${OC_CONFIG_FILE}" \
                "OPENCLAW_STATE_DIR=${OC_DATA_DIR}/.openclaw" \
            bash -c "cd '${OC_DATA_DIR}' && ${cmd}"
    else
        bash -c "cd '${OC_DATA_DIR}' && ${cmd}"
    fi
}

# ============================================================================
# 服务管理函数
# ============================================================================

# 检查进程是否在运行
check_process()
{
    local pid=$1
    if [ -z "${pid}" ]; then
        return 1
    fi
    if ps -p "${pid}" > /dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

# 停止 OpenClaw 网关进程
stop_openclaw_gateway()
{
    install_log "停止 OpenClaw Gateway..."

    if [ -f "${PID_FILE}" ]; then
        local pid
        pid=$(cat "${PID_FILE}" 2>/dev/null)
        if [ -n "${pid}" ] && check_process "${pid}"; then
            kill -TERM "${pid}" 2>/dev/null
            local count=0
            while check_process "${pid}" && [ $count -lt 10 ]; do
                sleep 1
                count=$((count + 1))
            done
            if check_process "${pid}"; then
                kill -9 "${pid}" 2>/dev/null
            fi
        fi
        rm -f "${PID_FILE}"
    fi

    # 兜底：杀残留的 openclaw 相关进程
    pkill -f "openclaw.*gateway" 2>/dev/null || true
    pkill -f "openclaw.*daemon" 2>/dev/null || true

    install_log "OpenClaw Gateway 已停止"
}

# ============================================================================
# 清理函数
# ============================================================================

# 删除临时文件（保留配置）
clean_temp_files()
{
    install_log "清理临时文件..."
    rm -f "${LOG_FILE}"
    rm -f "${PID_FILE}"
    install_log "临时文件清理完成"
}

# 删除所有用户数据
clean_all_data()
{
    install_log "删除所有用户数据..."

    if [ -d "${OC_DATA_DIR}" ]; then
        install_log "  清空数据目录: ${OC_DATA_DIR}"
        rm -rf "${OC_DATA_DIR}"
    fi

    if [ -d "${TRIM_PKGVAR}" ] && [ "$(ls -A ${TRIM_PKGVAR} 2>/dev/null)" != "" ]; then
        find ${TRIM_PKGVAR} -mindepth 1 -delete 2>/dev/null || true
    fi

    install_log "所有数据删除完成"
}

# 升级临时清理（保留用户配置）
clean_upgrade_temp()
{
    install_log "清理升级临时数据（保留用户配置）..."
    rm -f "${PID_FILE}"
    rm -f "${LOG_FILE}"
    install_log "升级临时数据清理完成（用户配置已保留）"
}

# ============================================================================
# Extension/Docs 补丁：从打包的源文件恢复缺失的 plugin 源码和文档模板
# ============================================================================
patch_extensions_and_docs()
{
    local OC_PKG="${OC_GLOBAL}/lib/node_modules/openclaw"
    local PATCH_DIR="${TRIM_APPDEST}/server/extension_patches"
    local DOCS_PATCH="${TRIM_APPDEST}/server/docs_patch"

    # 恢复 extension 源文件（递归复制，包含 src/ 子目录）
    if [ -d "${PATCH_DIR}" ]; then
        install_log "正在恢复 extension 插件源文件..."
        for ext_dir in "${PATCH_DIR}"/*/; do
            local ext_name=$(basename "$ext_dir")
            local target="${OC_PKG}/extensions/${ext_name}"
            if [ -d "${target}" ]; then
                $CP "${ext_dir}". "${target}/" 2>/dev/null || true
                install_log "  已恢复: ${ext_name}"
            fi
        done
        install_log "Extension 插件源文件恢复完成"
    fi

    # 恢复 docs 目录
    if [ -d "${DOCS_PATCH}" ] && [ ! -d "${OC_PKG}/docs" ]; then
        install_log "正在恢复 docs 文档模板..."
        $CP "${DOCS_PATCH}" "${OC_PKG}/docs"
        install_log "Docs 文档模板恢复完成"
    fi
}

# ============================================================================
# 安装钩子函数
# ============================================================================

install_init()
{
    log_step "install_init"
    exit 0
}

install_callback()
{
    log_step "install_callback"

    # 1. 创建必要的目录
    $MKDIR "${OC_DATA_DIR}"
    $MKDIR "${OC_CONFIG_DIR}"
    $MKDIR "${OC_DATA_DIR}/.openclaw/workspace"

    # 2. 创建专用用户（如果不存在）
    if ! id "${APP_USER}" &>/dev/null; then
        useradd -r -s /bin/false -d "${OC_DATA_DIR}" -M "${APP_USER}" 2>/dev/null || true
        install_log "已创建系统用户: ${APP_USER}"
    fi

    # 3. 设置目录权限
    chown -R "${APP_USER}:${APP_GROUP}" "${OC_DATA_DIR}"
    chown -R "${APP_USER}:${APP_GROUP}" "${TRIM_PKGVAR}"
    chmod 755 "${OC_DATA_DIR}"

    # 4. 确保 OpenClaw 二进制可执行
    chmod +x "${OC_BIN}" 2>/dev/null || true
    chmod +x "${NODE_BIN}" 2>/dev/null || true

    # 4.1 恢复 extension 源文件和 docs 模板
    patch_extensions_and_docs

    # 5. 初始化 OpenClaw 配置（非交互式）
    install_log "初始化 OpenClaw 配置..."
    run_as_openclaw "openclaw onboard --non-interactive --accept-risk" 2>&1 | install_log || true

    # 6. 配置网关参数
    install_log "配置网关参数..."
    run_as_openclaw "openclaw config set gateway.port ${GATEWAY_PORT}" 2>&1 | install_log || true
    run_as_openclaw "openclaw config set gateway.bind lan" 2>&1 | install_log || true
    run_as_openclaw "openclaw config set gateway.mode local" 2>&1 | install_log || true

    # 7. 生成随机认证令牌
    local GATEWAY_TOKEN
    GATEWAY_TOKEN=$(openssl rand -hex 24 2>/dev/null || head -c 48 /dev/urandom | od -An -tx1 | tr -d ' \n' | head -c 48)
    run_as_openclaw "openclaw config set gateway.auth.token '${GATEWAY_TOKEN}'" 2>&1 | install_log || true
    run_as_openclaw "openclaw config set gateway.auth.mode token" 2>&1 | install_log || true

    # 8. 配置 Web 控制台允许 HTTP 访问（CLI 方式 + 直接写 JSON 双保险）
    run_as_openclaw "openclaw config set gateway.controlUi.allowInsecureAuth true" 2>&1 | install_log || true
    run_as_openclaw "openclaw config set gateway.controlUi.dangerouslyDisableDeviceAuth true" 2>&1 | install_log || true
    run_as_openclaw "openclaw config set gateway.controlUi.dangerouslyAllowHostHeaderOriginFallback true" 2>&1 | install_log || true
    run_as_openclaw "openclaw config set gateway.controlUi.allowedOrigins '[\"*\"]'" 2>&1 | install_log || true

    # 8.1 直接修改 JSON 配置文件（双保险：防止 CLI 未生效）
    if [ -f "${OC_CONFIG_FILE}" ]; then
        install_log "直接写入 JSON 配置文件（双保险）..."
        if command -v jq &>/dev/null; then
            local TMP_CFG="${OC_CONFIG_FILE}.tmp"
            jq '.gateway.controlUi.allowInsecureAuth = true |
                .gateway.controlUi.dangerouslyDisableDeviceAuth = true |
                .gateway.controlUi.dangerouslyAllowHostHeaderOriginFallback = true |
                .gateway.controlUi.allowedOrigins = ["*"] |
                .gateway.auth.token = "'"${GATEWAY_TOKEN}"'" |
                .gateway.auth.mode = "token" |
                .gateway.port = '"${GATEWAY_PORT}"' |
                .gateway.bind = "lan" |
                .gateway.mode = "local"' \
                "${OC_CONFIG_FILE}" > "${TMP_CFG}" && \
            mv -f "${TMP_CFG}" "${OC_CONFIG_FILE}" && \
            chown "${APP_USER}:${APP_GROUP}" "${OC_CONFIG_FILE}"
            install_log "JSON 配置文件已更新"
        else
            # 无 jq 时用 python3 兜底
            python3 -c "
import json, sys
try:
    with open('${OC_CONFIG_FILE}', 'r') as f:
        cfg = json.load(f)
    gw = cfg.setdefault('gateway', {})
    gw['port'] = ${GATEWAY_PORT}
    gw['bind'] = 'lan'
    gw['mode'] = 'local'
    auth = gw.setdefault('auth', {})
    auth['token'] = '${GATEWAY_TOKEN}'
    auth['mode'] = 'token'
    ui = gw.setdefault('controlUi', {})
    ui['allowInsecureAuth'] = True
    ui['dangerouslyDisableDeviceAuth'] = True
    ui['dangerouslyAllowHostHeaderOriginFallback'] = True
    ui['allowedOrigins'] = ['*']
    with open('${OC_CONFIG_FILE}', 'w') as f:
        json.dump(cfg, f, indent=2)
    print('OK: config updated via python3')
except Exception as e:
    print(f'WARN: {e}', file=sys.stderr)
" 2>&1 | install_log || true
        fi
    fi

    # 9. 保存令牌到独立文件以供参考
    echo "${GATEWAY_TOKEN}" > "${TRIM_PKGVAR}/gateway_token"
    chown "${APP_USER}:${APP_GROUP}" "${TRIM_PKGVAR}/gateway_token"
    chmod 600 "${TRIM_PKGVAR}/gateway_token"

    # 10. 动态更新飞牛桌面 iframe URL，带上 token 参数
    local UI_CONFIG="${TRIM_APPDEST}/ui/config"
    if [ -f "${UI_CONFIG}" ]; then
        install_log "更新桌面 iframe URL (附加 token)..."
        if command -v jq &>/dev/null; then
            local TMP_UI="${UI_CONFIG}.tmp"
            jq '.[".url"]["openclaw.Application"].url = "/?token='"${GATEWAY_TOKEN}"'"' \
                "${UI_CONFIG}" > "${TMP_UI}" && \
            mv -f "${TMP_UI}" "${UI_CONFIG}"
            install_log "ui/config 已更新"
        else
            sed -i 's|"url": "/"|"url": "/?token='"${GATEWAY_TOKEN}"'"|g' "${UI_CONFIG}" 2>/dev/null || true
            install_log "ui/config 已更新 (sed)"
        fi
    fi

    # 11. 生成 token.js 供 index.html 页面读取
    local TOKEN_JS="${TRIM_APPDEST}/ui/token.js"
    echo "window.__OPENCLAW_TOKEN__ = '${GATEWAY_TOKEN}';" > "${TOKEN_JS}"
    chmod 644 "${TOKEN_JS}"
    install_log "已生成 token.js"

    install_log "安装完成"
    install_log "Gateway Token: ${GATEWAY_TOKEN}"
    install_log "Web 控制台: http://<NAS_IP>:${GATEWAY_PORT}/?token=${GATEWAY_TOKEN}"

    exit 0
}

# ============================================================================
# 卸载钩子函数
# ============================================================================

uninstall_init()
{
    log_step "uninstall_init"
    stop_openclaw_gateway
    exit 0
}

uninstall_callback()
{
    log_step "uninstall_callback"

    UPGRADE_FLAG="${TRIM_PKGVAR}/.upgrading"

    if [ -f "${UPGRADE_FLAG}" ]; then
        install_log "检测到升级标记，进入升级模式"
        stop_openclaw_gateway
        clean_upgrade_temp
        install_log "升级准备完成，用户配置已保留"
        exit 0
    fi

    install_log "进入完全卸载流程"
    stop_openclaw_gateway

    if [ "$wizard_delete_data" = "true" ]; then
        install_log "用户选择：删除所有数据"
        clean_all_data

        # 删除系统用户
        if id "${APP_USER}" &>/dev/null; then
            userdel -r "${APP_USER}" 2>/dev/null || userdel "${APP_USER}" 2>/dev/null || true
            install_log "已删除系统用户: ${APP_USER}"
        fi

        install_log "OpenClaw 已完全卸载，所有数据已删除"
    else
        install_log "用户选择：保留配置数据"
        clean_temp_files
        install_log "OpenClaw 已卸载，但配置数据已保留供将来使用"
        install_log "保留的数据目录: ${OC_DATA_DIR}"
    fi

    exit 0
}

# ============================================================================
# 升级钩子函数
# ============================================================================

upgrade_init()
{
    log_step "upgrade_init"

    UPGRADE_FLAG="${TRIM_PKGVAR}/.upgrading"
    touch "${UPGRADE_FLAG}"
    install_log "已创建升级标记: ${UPGRADE_FLAG}"

    stop_openclaw_gateway

    install_log "升级前准备完成"
    exit 0
}

upgrade_callback()
{
    log_step "upgrade_callback"

    UPGRADE_FLAG="${TRIM_PKGVAR}/.upgrading"
    rm -f "${UPGRADE_FLAG}"
    install_log "已删除升级标记"

    # 确保数据目录存在
    $MKDIR "${OC_DATA_DIR}"
    $MKDIR "${OC_CONFIG_DIR}"

    # 确保用户存在
    if ! id "${APP_USER}" &>/dev/null; then
        useradd -r -s /bin/false -d "${OC_DATA_DIR}" -M "${APP_USER}" 2>/dev/null || true
    fi

    # 修复权限
    chown -R "${APP_USER}:${APP_GROUP}" "${OC_DATA_DIR}"
    chown -R "${APP_USER}:${APP_GROUP}" "${TRIM_PKGVAR}"

    # 恢复 extension 源文件和 docs 模板
    patch_extensions_and_docs

    # 修复: 升级后重新注入 gateway token 到 ui/config 和 token.js
    if [ -f "${TRIM_PKGVAR}/gateway_token" ]; then
        local GW_TOKEN
        GW_TOKEN=$(cat "${TRIM_PKGVAR}/gateway_token" 2>/dev/null)
        if [ -n "${GW_TOKEN}" ]; then
            # 更新 ui/config URL
            local UI_CONFIG="${TRIM_APPDEST}/ui/config"
            if [ -f "${UI_CONFIG}" ]; then
                if command -v jq &>/dev/null; then
                    local TMP_UI="${UI_CONFIG}.tmp"
                    jq '.[".url"]["openclaw.Application"].url = "/?token='"${GW_TOKEN}"'"' \
                        "${UI_CONFIG}" > "${TMP_UI}" && mv -f "${TMP_UI}" "${UI_CONFIG}"
                else
                    sed -i 's|"url": "/"|"url": "/?token='"${GW_TOKEN}"'"|g' "${UI_CONFIG}" 2>/dev/null || true
                fi
            fi
            # 重新生成 token.js
            local TOKEN_JS="${TRIM_APPDEST}/ui/token.js"
            echo "window.__OPENCLAW_TOKEN__ = '${GW_TOKEN}';" > "${TOKEN_JS}"
            chmod 644 "${TOKEN_JS}"
            install_log "升级后已重新注入 gateway token"
        fi
    fi

    install_log "升级完成"
    exit 0
}
