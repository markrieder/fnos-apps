#!/bin/sh
APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR=$1

DATA_DIR="${APP_DATA_DIR}/data"
LOG_DIR="${APP_DATA_DIR}/logs"
DB_FILE="${DATA_DIR}/et.db"
API_HOST="http://127.0.0.1:${TRIM_SERVICE_PORT}"

mkdir -p "$DATA_DIR" "$LOG_DIR"

cd "$APP_DIR" || exit 1
exec ./easytier-web-embed \
    --db "$DB_FILE" \
    --file-log-dir "$LOG_DIR" \
    --api-server-port "${TRIM_SERVICE_PORT}" \
    --api-host "$API_HOST" \
    --config-server-port 22020 \
    --config-server-protocol udp
